# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5433/car_yard

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200

# OSINT Collection Settings
RSS_FETCH_INTERVAL=300
API_FETCH_INTERVAL=600
MAX_ARTICLES_PER_SOURCE=50

# NLP Processing Settings
SENTIMENT_THRESHOLD=0.6
EVENT_CONFIDENCE_THRESHOLD=0.7
MENTION_CONFIDENCE_THRESHOLD=0.8

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/osint_processor.log

# Rate Limiting
REQUEST_DELAY=1.0
MAX_RETRIES=3

# Content Deduplication
SIMILARITY_THRESHOLD=0.9
