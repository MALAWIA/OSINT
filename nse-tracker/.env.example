# Database Configuration
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_USER=nse_tracker
POSTGRES_DB=nse_tracker
DATABASE_URL=postgresql://nse_tracker:your_secure_password_here@postgres:5432/nse_tracker

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# External API Keys
NEWSAPI_KEY=your_newsapi_key_here
ALPHAVANTAGE_KEY=your_alphavantage_key_here

# NSE Authentication API (Django Backend)
NSE_AUTH_API_URL=http://localhost:8000/api

# Application Configuration
APP_NAME=NSE Intelligence Tracker
APP_VERSION=1.0.0
DEBUG=true

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30

# Cache TTL (in seconds)
NEWS_CACHE_TTL=1800  # 30 minutes
STOCK_CACHE_TTL=300  # 5 minutes

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
