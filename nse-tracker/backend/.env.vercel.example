# Production Environment Variables for Vercel Deployment

# Supabase Configuration
USE_SUPABASE=true
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DB_URL=postgresql://postgres:your_password@aws-1-eu-west-1.pooler.supabase.co:6543/postgres

# Database Configuration (Fallback)
DATABASE_URL=postgresql://username:password@localhost:5432/nse_tracker
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_USER=your_postgres_user
POSTGRES_DB=nse_tracker

# JWT Configuration
JWT_SECRET=your_super_secure_production_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
ALLOWED_ORIGINS=https://your-domain.vercel.app,https://*.vercel.app

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# API Keys
NEWSAPI_KEY=your_newsapi_key
ALPHAVANTAGE_KEY=your_alphavantage_key

# Application Settings
DEBUG=false
ENVIRONMENT=production

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Logging
LOG_LEVEL=INFO

# Cache TTL
NEWS_CACHE_TTL=1800
STOCK_CACHE_TTL=300

# Task Configuration
NEWS_FETCH_INTERVAL_MINUTES=30
STOCK_FETCH_INTERVAL_MINUTES=5

# API URLs
NEWSAPI_BASE_URL=https://newsapi.org/v2
ALPHAVANTAGE_BASE_URL=https://www.alphavantage.co/query
