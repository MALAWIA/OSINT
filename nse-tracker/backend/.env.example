# NSE Intelligence Tracker Environment Variables

# Application Settings
APP_NAME="NSE Intelligence Tracker"
APP_VERSION="1.0.0"
DEBUG=false

# Database Configuration (Regular PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/nse_tracker"
POSTGRES_PASSWORD="your_postgres_password"
POSTGRES_USER="your_postgres_user"
POSTGRES_DB="nse_tracker"

# Supabase Configuration (Alternative to PostgreSQL)
USE_SUPABASE=false
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"
SUPABASE_DB_URL="postgresql://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres"

# Redis Configuration
REDIS_URL="redis://localhost:6379/0"

# JWT Authentication
JWT_SECRET="your_super_secret_jwt_key_here"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# External API Keys
NEWSAPI_KEY="your_newsapi_key"
ALPHAVANTAGE_KEY="your_alphavantage_key"

# CORS Settings
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30

# Cache TTL (seconds)
NEWS_CACHE_TTL=1800
STOCK_CACHE_TTL=300

# Celery Configuration
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/0"

# Logging
LOG_LEVEL="INFO"
LOG_FORMAT="json"

# News Sources Configuration
GOOGLE_NEWS_QUERY="Nairobi Stock Exchange OR NSE OR Kenya market"
NEWS_SOURCES="businessdailyafrica.com,standardmedia.co.ke,nation.africa,citizentv.co.ke,kbc.co.ke"

# NSE Stock Symbols
NSE_SYMBOLS="SCOM,EQTY,KCB,COOP,NCBA,ABSA,DTK,JUB,BAT,EABL,UAP,CFC,ICDC,NMG,TPS,WPP,BAM,BRK,GDC,HFG,KAPC,LONMOT,MUMIAS,NSEL,OLGE,PORTLAND,RVA,SAS,TSL,UMASH"

# External API URLs
NEWSAPI_BASE_URL="https://newsapi.org/v2"
ALPHAVANTAGE_BASE_URL="https://www.alphavantage.co/query"

# Task Configuration
NEWS_FETCH_INTERVAL_MINUTES=30
STOCK_FETCH_INTERVAL_MINUTES=5

# Supabase Setup Instructions:
# 1. Create a new project at https://supabase.com
# 2. Go to Settings > API to get your URL and keys
# 3. Go to Settings > Database to get the connection string
# 4. Set USE_SUPABASE=true and fill in the Supabase variables above
# 5. Update your database URL to use the Supabase connection string
