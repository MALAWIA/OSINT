# Database Configuration
POSTGRES_PASSWORD=nse_tracker_2024
POSTGRES_USER=nse_tracker
POSTGRES_DB=nse_tracker
DATABASE_URL=postgresql://nse_tracker:nse_tracker_2024@postgres:5432/nse_tracker

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_this_in_production_2024
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# External API Keys (you need to get these)
NEWSAPI_KEY=your_newsapi_key_here
ALPHAVANTAGE_KEY=your_alphavantage_key_here

# Application Configuration
APP_NAME=NSE Intelligence Tracker
APP_VERSION=1.0.0
DEBUG=true

# NSE Authentication API (Django Backend)
NSE_AUTH_API_URL=http://localhost:8001/api

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30

# Cache TTL (in seconds)
NEWS_CACHE_TTL=1800
STOCK_CACHE_TTL=300

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# News Sources
GOOGLE_NEWS_QUERY=Nairobi Stock Exchange OR NSE OR Kenya market
NEWS_SOURCES=businessdailyafrica.com,standardmedia.co.ke,nation.africa,citizentv.co.ke,kbc.co.ke

# Stock Data
NSE_SYMBOLS=SCOM,EQTY,KCB,COOP,NCBA,ABSA,DTK,JUB,BAT,EABL,UAP,CFC,ICDC,NMG,TPS,WPP,BAMB,BRK,GDC,HFG,KAPC,LONMOT,MUMIAS,NSEL,OLGE,PORTLAND,RVA,SAS,TSL,UMASH

# External API URLs
NEWSAPI_BASE_URL=https://newsapi.org/v2
ALPHAVANTAGE_BASE_URL=https://www.alphavantage.co/query

# Task Configuration
NEWS_FETCH_INTERVAL_MINUTES=30
STOCK_FETCH_INTERVAL_MINUTES=5
