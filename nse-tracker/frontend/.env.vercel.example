# Frontend Environment Variables for Vercel Deployment

# API Configuration
REACT_APP_API_URL=https://your-backend-domain.vercel.app/api
REACT_APP_WS_URL=wss://your-backend-domain.vercel.app

# Application Configuration
REACT_APP_ENVIRONMENT=production
REACT_APP_DEBUG=false

# Supabase Configuration (if using client-side Supabase)
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_NOTIFICATIONS=true

# External Services
REACT_APP_NEWS_API_KEY=your_newsapi_key
REACT_APP_ALPHAVANTAGE_KEY=your_alphavantage_key
